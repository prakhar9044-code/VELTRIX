rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- 0. Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 3. Primitive Definitions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 1. User Root ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['preferences', 'displayName', 'photoURL']);

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'createdAt'])
               && data.uid == request.auth.uid
               && data.email is string && data.email.size() > 3
               && (data.createdAt is string || data.createdAt is timestamp);
      }

      // --- 2. Expenses ---
      match /expenses/{expenseId} {
        // Secure List Queries: Explicitly evaluate resource.data against auth.uid
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExpense(incoming());
        allow update: if isOwner(userId) && isValidExpense(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'description', 'tags', 'date', 'timestamp']);
        allow delete: if isOwner(userId);

        function isValidExpense(data) {
          return data.keys().hasAll(['userId', 'amount', 'category', 'timestamp'])
                 && data.userId == request.auth.uid
                 && data.amount is number && data.amount >= 0
                 && data.category is string && data.category.size() > 0
                 && (data.timestamp is string || data.timestamp is timestamp);
        }
      }

      // --- 3. Insights ---
      match /insights/{insightId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInsight(incoming());
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(userId);

        function isValidInsight(data) {
          return data.keys().hasAll(['userId', 'type', 'content', 'timestamp'])
                 && data.userId == request.auth.uid
                 && data.type in ['weekly_summary', 'leak_detection', 'pattern_alert', 'coaching_nudge']
                 && data.content is string && data.content.size() > 0
                 && (data.timestamp is string || data.timestamp is timestamp);
        }
      }

      // --- 4. Subscriptions ---
      match /subscriptions/{subId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSubscription(incoming());
        allow update: if isOwner(userId) && isValidSubscription(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'amount', 'billingCycle', 'nextBillingDate', 'active']);
        allow delete: if isOwner(userId);

        function isValidSubscription(data) {
          return data.keys().hasAll(['userId', 'name', 'amount', 'billingCycle'])
                 && data.userId == request.auth.uid
                 && data.name is string && data.name.size() > 0
                 && data.amount is number && data.amount >= 0
                 && data.billingCycle in ['monthly', 'yearly'];
        }
      }
    }
  }
}
