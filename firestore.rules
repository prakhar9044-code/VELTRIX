rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) 
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferences', 'displayName', 'photoURL']));

      function isValidUser(data) {
        return data.uid == request.auth.uid 
               && data.email is string
               && data.createdAt is string;
      }

      // --- Expenses Rules ---
      match /expenses/{expenseId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExpense(request.resource.data);
        allow update: if isOwner(userId) && isValidExpense(request.resource.data)
                      && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'category', 'description', 'tags', 'date']));
        allow delete: if isOwner(userId);

        function isValidExpense(data) {
          return data.userId == request.auth.uid
                 && data.amount is number
                 && data.category is string
                 && data.timestamp is string;
        }
      }

      // --- Insights Rules ---
      match /insights/{insightId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInsight(request.resource.data);
        allow update: if isOwner(userId) && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
        allow delete: if isOwner(userId);

        function isValidInsight(data) {
          return data.userId == request.auth.uid
                 && data.type in ['weekly_summary', 'leak_detection', 'pattern_alert', 'coaching_nudge']
                 && data.content is string
                 && data.timestamp is string;
        }
      }

      // --- Subscriptions Rules ---
      match /subscriptions/{subId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSubscription(request.resource.data);
        allow update: if isOwner(userId) && isValidSubscription(request.resource.data)
                      && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'amount', 'billingCycle', 'nextBillingDate', 'active']));
        allow delete: if isOwner(userId);

        function isValidSubscription(data) {
          return data.userId == request.auth.uid
                 && data.name is string
                 && data.amount is number
                 && data.billingCycle in ['monthly', 'yearly'];
        }
      }
    }
  }
}
